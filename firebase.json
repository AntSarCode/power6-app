{
  "hosting": {
    "site": "power6-app-30bd8",
    "public": "power6_mobile/build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/support/**",
        "destination": "/support/index.html"
      },
      {
        "source": "/privacy/**",
        "destination": "/privacy/index.html"
      },
      {
        "source": "/terms/**",
        "destination": "/terms/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
